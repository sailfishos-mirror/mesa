      <GPU>Mali-G710</GPU>
      <GPU>Mali-G715</GPU>
      <GPU>Mali-G720</GPU>
      <GPU>Mali-G725</GPU>
      <GPU>Mali G1</GPU>
    </SupportedGPUs>
    <Perfetto>
      <Groups>
        <GroupName>Vertices</GroupName>
      </Groups>
    </Perfetto>
  </CounterInfo>
