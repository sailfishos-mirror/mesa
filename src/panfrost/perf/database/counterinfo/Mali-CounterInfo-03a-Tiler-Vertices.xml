  <CounterInfo>
    <MachineName>MaliTilerPosShadThreadPerPrim</MachineName>
    <StableID>65666</StableID>
    <HumanName>Position shader threads per input primitive</HumanName>
    <GroupName>Geometry Efficiency</GroupName>
    <GroupHumanName>Position threads/input primitive</GroupHumanName>
    <Units>threads</Units>
    <Trend>Lower better</Trend>
    <Visibility>Novice</Visibility>
    <ShortDescription>
      The number of position shader invocations per input primitive.
    </ShortDescription>
    <LongDescription>
      This expression defines the number of position shader threads per input
      primitive.

      Efficient meshes with a good vertex reuse have average less than 1.5
      vertices shaded per triangle, as vertex computation is shared by multiple
      primitives. Minimize this number by reusing vertices for nearby
      primitives, improving temporal locality of index reuse, and avoiding
      unused values in the active index range.
    </LongDescription>
    <Equation>
      MaliTilerPosShadThread / MaliGeomTotalPrim
    </Equation>
    <SupportedGPUs>
      <GPU>Mali-G31</GPU>
      <GPU>Mali-G51</GPU>
      <GPU>Mali-G52</GPU>
      <GPU>Mali-G71</GPU>
      <GPU>Mali-G72</GPU>
      <GPU>Mali-G76</GPU>
      <GPU>Mali-G77</GPU>
      <GPU>Mali-G78</GPU>
      <GPU>Mali-G710</GPU>
      <GPU>Mali-G715</GPU>
      <GPU>Mali-G720</GPU>
      <GPU>Mali-G725</GPU>
      <GPU>Mali G1</GPU>
    </SupportedGPUs>
    <Perfetto>
      <Groups>
        <GroupName>Vertices</GroupName>
      </Groups>
    </Perfetto>
  </CounterInfo>
