  <CounterInfo>
    <MachineName>MaliTilerPosShadTask</MachineName>
    <SourceName>IDVS_POS_SHAD_REQ</SourceName>
    <SourceAlias>POS_SHADER_WARPS</SourceAlias>
    <StableID>159</StableID>
    <HumanName>Tiler position shading requests</HumanName>
    <GroupName>Tiler Shading Requests</GroupName>
    <GroupHumanName>Position shading requests</GroupHumanName>
    <Units>requests</Units>
    <Trend>Lower better</Trend>
    <Visibility>Novice</Visibility>
    <ShortDescription>
      The number of position shading requests in the tiler geometry flow.
    </ShortDescription>
    <LongDescription>
      This counter increments for every position shading request in the tiler
      geometry flow. Position shading runs the first part of the vertex shader,
      computing the position required to perform clipping and culling. A vertex
      that has been evicted from the post-transform cache must be reshaded if
      used again, so your index buffers must have good spatial locality of
      index reuse.

      Each request contains {{C::MaliGPUGeomTaskSize.equation}} vertices.

      Note that not all types of draw call use this tiler workflow, so this
      counter might not account for all submitted geometry.
    </LongDescription>
    <SupportedGPUs>
      <GPU>Mali-G31</GPU>
      <GPU>Mali-G51</GPU>
      <GPU>Mali-G52</GPU>
      <GPU>Mali-G71</GPU>
      <GPU>Mali-G72</GPU>
      <GPU>Mali-G76</GPU>
      <GPU>Mali-G77</GPU>
      <GPU>Mali-G78</GPU>
      <GPU>Mali-G710</GPU>
      <GPU>Mali-G715</GPU>
      <GPU>Mali-G720</GPU>
      <GPU>Mali-G725</GPU>
      <GPU>Mali G1</GPU>
    </SupportedGPUs>
    <Perfetto>
      <Groups>
        <GroupName>Vertices</GroupName>
      </Groups>
    </Perfetto>
  </CounterInfo>
