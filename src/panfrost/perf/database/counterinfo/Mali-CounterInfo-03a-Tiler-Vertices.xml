  <CounterInfo>
    <MachineName>MaliTilerVarShadTask</MachineName>
    <SourceName>IDVS_VAR_SHAD_REQ</SourceName>
    <SourceAlias>VAR_SHADER_WARPS</SourceAlias>
    <StableID>175</StableID>
    <HumanName>Tiler varying shading requests</HumanName>
    <GroupName>Tiler Shading Requests</GroupName>
    <GroupHumanName>Varying shading requests</GroupHumanName>
    <Units>requests</Units>
    <Trend>Lower better</Trend>
    <Visibility>Novice</Visibility>
    <ShortDescription>
      The number of varying shading requests in the tiler geometry flow.
    </ShortDescription>
    <LongDescription>
      This counter increments for every varying shading request in the tiler
      geometry flow. Varying shading runs the second part of the vertex shader,
      for any primitive that survives clipping and culling. The same vertex is
      shaded multiple times if it has been evicted from the post-transform
      cache before reuse occurs. Keep good spatial locality of index reuse in
      your index buffers.

      Each request contains {{C::MaliGPUGeomTaskSize.equation}} vertices.

      Note that not all types of draw call use this tiler workflow, so this
      counter might not account for all submitted geometry.
    </LongDescription>
    <SupportedGPUs>
      <GPU>Mali-G31</GPU>
      <GPU>Mali-G51</GPU>
      <GPU>Mali-G52</GPU>
      <GPU>Mali-G71</GPU>
      <GPU>Mali-G72</GPU>
      <GPU>Mali-G76</GPU>
      <GPU>Mali-G77</GPU>
      <GPU>Mali-G78</GPU>
      <GPU>Mali-G710</GPU>
      <GPU>Mali-G715</GPU>
    </SupportedGPUs>
    <Perfetto>
      <Groups>
        <GroupName>Vertices</GroupName>
      </Groups>
    </Perfetto>
  </CounterInfo>
