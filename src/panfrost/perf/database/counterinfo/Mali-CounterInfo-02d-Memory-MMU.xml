  <CounterInfo>
    <MachineName>MaliMMUL3HitRate</MachineName>
    <StableID>570</StableID>
    <HumanName>MMU level 3 lookup TLB hit rate</HumanName>
    <GroupName>MMU Hit Rate</GroupName>
    <GroupHumanName>Level 3 hit rate</GroupHumanName>
    <Units>percent</Units>
    <Trend>Higher better</Trend>
    <Visibility>Advanced system</Visibility>
    <ShortDescription>
      The percentage hit rate of the TLB for level 3 table walks.
    </ShortDescription>
    <LongDescription>
      This expression defines the percentage hit rate of the main MMU TLB for
      level 3 table walks.
    </LongDescription>
    <Equation>
      (MaliMMUL3Hit / (MaliMMUL3Hit + MaliMMUL3Miss)) * 100
    </Equation>
    <SupportedGPUs>
